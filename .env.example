# Copy this file to `.env` (or set these in your shell) to enable real Claude
# analysis. Without a key, The Tiebreaker runs in deterministic demo/mock mode
# and still works end-to-end.

# Your Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the model. Defaults to the latest, most capable Opus.
# CLAUDE_MODEL=claude-opus-4-8
